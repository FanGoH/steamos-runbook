STEAMOS_NIC_INTERFACE=enp8s0
STEAMOS_USER=deck
STEAMOS_PLAYBOOK_DIR=/home/deck/steamos-playbook
STEAMOS_DISTROBOX_NAME=steamos-tools
STEAMOS_DISTROBOX_IMAGE=registry.fedoraproject.org/fedora:42

# Headscale / Tailscale (deck-tailscale install)
# Required for Tailscale re-login hints — set your Headscale URL here
TAILSCALE_LOGIN_SERVER=https://headscale.example.com
TAILSCALE_HOSTNAME=steamdeck
TAILSCALE_OPERATOR=deck
TAILSCALE_BIN=/opt/tailscale/tailscale

# Flatpak / services
OPENRGB_FLATPAK_ID=org.openrgb.OpenRGB
OPENRGB_UDEV_RULES=/etc/udev/rules.d/60-openrgb.rules
OPENRGB_PROFILE=ramoff
OPENRGB_SDK_HOST=127.0.0.1
OPENRGB_SDK_PORT=6742
SUNSHINE_USER_SERVICE=app-dev.lizardbyte.app.Sunshine.service

# AUR helper (optional; prefer Flatpaks on SteamOS tiny root)
AUR_HELPER=paru

# AppImage manager (Flatpak → /home)
GEARLEVER_FLATPAK_ID=it.mijorus.gearlever
FLATPAK_REMOTE=flathub
